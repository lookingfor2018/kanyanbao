# =========================
# Kanyanbao .env.example
# =========================

RUN_TIMEZONE=Asia/Shanghai
DEFAULT_RUN_MODE=manual

KZQ_USERNAME=
KZQ_PASSWORD=
KZQ_LOGIN_URL=https://www.kanzhiqiu.com/user/login.htm
KZQ_REPORT_HOME_URL=https://www.kanzhiqiu.com/newreport/reportHome.htm
DOWNLOAD_TIMEOUT_MS=60000
PDF_EXTRACT_TIMEOUT_MS=120000

SANITIZE_ENTITY_NAMES=
SANITIZE_PERSON_NAMES=
SANITIZE_EXTRA_PATTERNS=

SUMMARY_API_BASE_URL=https://gmn.chuangzuoli.com
SUMMARY_API_KEY=
SUMMARY_MODEL=gpt-5.3
GOOGLE_TRANSLATE_ENDPOINT=
GOOGLE_TRANSLATE_API_KEY=
MAX_SUMMARY_INPUT_TOKENS=17000
MAX_SUMMARY_OUTPUT_TOKENS=1800
MAX_LLM_CHUNKS_PER_REPORT=6
DAILY_LLM_TOKEN_BUDGET=500000

STORAGE_ENDPOINT=
STORAGE_REGION=
STORAGE_BUCKET=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_PREFIX=reports
SIGNED_URL_TTL_SECONDS=604800
SHORTLINK_BASE_URL=
SHORTLINK_SIGNING_KEY=
SHORTLINK_CODE_LENGTH=8
SHORTLINK_PROVIDER=static_redirect
SHORTLINK_API_ENDPOINT=
SHORTLINK_API_TOKEN=
SHORTLINK_VERIFY_REMOTE=false

FEISHU_ENABLE_PUSH=false
FEISHU_WEBHOOK_URL=
FEISHU_CHAT_ID=
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

SITE_BASE_URL=https://<github-user>.github.io/<repo>/

ENABLE_LIVE_ACQUISITION=false
ENABLE_ACCEPTANCE_STRICT=false
UNSAFE_SANITIZE_PASSTHROUGH=false
VERIFY_SIGNED_URL=true
VERIFY_SHORTLINK=true
LINK_VERIFY_TIMEOUT_MS=15000
